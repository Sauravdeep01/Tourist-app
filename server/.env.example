PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/appl_travel?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
CLIENT_URL=http://localhost:5173

# Initial accounts for DB seeding — required, no defaults are baked into code
ADMIN_EMAIL=
ADMIN_PASSWORD=
OWNER_EMAIL=
OWNER_PASSWORD=

# SMTP Configuration (optional — email notification is skipped silently if empty)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
