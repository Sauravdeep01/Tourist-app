PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/appl_travel?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
CLIENT_URL=http://localhost:5173

# Initial accounts for DB seeding — required, no defaults are baked into code
ADMIN_EMAIL=
ADMIN_PASSWORD=
OWNER_EMAIL=
OWNER_PASSWORD=

# SMTP Configuration — required in v1.5: signup cannot complete without a
# deliverable OTP email, and inquiry notifications also use this. Locally,
# if left empty, the code is only logged to the server console / exposed via
# the dev-only GET /api/auth/dev/otp/:email route (non-production only).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Cloudinary — image hosting for tour/destination/gallery photos (§6.2, §6.5b)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
